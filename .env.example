# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored. These credentials are shared by the app container
# (via NODE_CONFIG in docker-compose.yml) and the garage-init container.
#
# Format rules (Garage v1.x):
#   GARAGE_KEY_ID  -> "GK" + 24 hex chars
#   GARAGE_SECRET  -> 64 hex chars
# Generate a fresh secret with:  openssl rand -hex 32
GARAGE_KEY_ID=GKxxxxxxxxxxxxxxxxxxxxxxxx
GARAGE_SECRET=replace-with-64-hex-characters

# Internal Garage cluster secrets (consumed by the garage + garage-init containers)
#   GARAGE_RPC_SECRET   -> 64 hex chars (openssl rand -hex 32)
GARAGE_RPC_SECRET=replace-with-64-hex-characters
GARAGE_ADMIN_TOKEN=replace-with-a-random-admin-token

# Browser-facing asset URLs (OPTIONAL — defaults to *.localhost:3902 for local dev).
# On a server deployment, set these to public hostnames that your reverse proxy
# (e.g. Caddy) routes to Garage's web port 3902 with the Host header rewritten
# to <bucket-name>.localhost, e.g.:
#   assets-snapshots.example.com { reverse_proxy localhost:3902 { header_up Host trinket-snapshots.localhost } }
# ASSET_HOST_USERASSETS=https://assets-user.example.com
# ASSET_HOST_SNAPSHOTS=https://assets-snapshots.example.com
# ASSET_HOST_MATERIALS=https://assets-materials.example.com
# ASSET_HOST_USERAVATARS=https://assets-avatars.example.com
# ASSET_HOST_EXPORTS=https://assets-exports.example.com
